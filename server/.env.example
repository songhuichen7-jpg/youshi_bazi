# Environment mode: dev / prod / test
ENV=dev
LOG_LEVEL=INFO

# Postgres connection (asyncpg driver)
# Local dev: docker-compose up postgres 后
DATABASE_URL=postgresql+asyncpg://bazi:bazi@localhost:5432/bazi_dev

# Application-layer encryption key (64 hex chars = 32 bytes)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Sentinel __CHANGE_ME_64_HEX__ blocks startup
ENCRYPTION_KEK=__CHANGE_ME_64_HEX__

# Aliyun SMS (Plan 3 onwards)
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_SECRET=
ALIYUN_SMS_TEMPLATE=

# MiMo Token Plan LLM (OpenAI-compatible API)
# Put the real key in server/.env only; never commit it.
LLM_API_KEY=
LLM_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro
LLM_FAST_MODEL=mimo-v2.5
LLM_FALLBACK_MODEL=mimo-v2.5
LLM_THINKING=enabled

# Share card MVP
WX_APP_ID=
WX_APP_SECRET=
ADMIN_TOKEN=

# CORS — 跨域部署填 origin 列表，逗号分隔。同源部署（nginx 反代到一个
# origin）留空，不挂 CORSMiddleware。
# 例: CORS_ORIGINS=https://youshi.fun,https://beta.youshi.fun
CORS_ORIGINS=

# 全局 API rate-limit
# 60 req/min/key 是温和水平。设了 REDIS_URL 时跨 worker 共享窗口；
# 没设走 in-memory（单 worker 准确，多 worker 实际 N×limit）。
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Redis（可选）— 多 worker 部署必须，本地 dev / 单 worker 可留空。
# 设了之后 rate-limit + 会话锁自动走 Redis；不设走 in-memory 兜底。
# 例: REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# DB 连接池 — 默认 5 + 10 (单 worker dev 够)
# 生产推荐 20 + 30 (50 总连接 / worker)
# PG max_connections 默认 100，部署时算 worker × pool 不超过 70%
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
