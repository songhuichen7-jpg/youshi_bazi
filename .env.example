# ─── 基础 ───────────────────────────────────────────────────────────
ENV=dev                  # dev | prod
LOG_LEVEL=INFO           # DEBUG | INFO | WARN | ERROR
PORT=3101

# ─── 数据库 ──────────────────────────────────────────────────────────
# async driver 必须用 postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://youshi:CHANGE_ME@localhost:5432/youshi_dev
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# ─── Redis（多 worker 必填） ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── 加密 ────────────────────────────────────────────────────────────
# 用户手机号 E2E 加密的 KEK（master key），64 hex 字符
# 生成：python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEK=

# ─── LLM ─────────────────────────────────────────────────────────────
# OpenAI-compatible API。已测过 DeepSeek、MiMo、OpenAI。
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-reasoner            # 主回答模型（长上下文、思考强）
LLM_FAST_MODEL=deepseek-chat            # router / chips / 短结构化任务
LLM_FALLBACK_MODEL=deepseek-chat        # 主模型失败兜底

# ─── 速率限制 ────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── CORS（同源 nginx 反代不需要填） ──────────────────────────────────
CORS_ORIGINS=

# ─── 第三方（可选） ──────────────────────────────────────────────────
# 短信（阿里云）
# ALIYUN_SMS_KEY=
# ALIYUN_SMS_SECRET=
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=

# 微信
# WX_APP_ID=
# WX_APP_SECRET=

# 支付（占位，按需启用）
# PAY_PROVIDER=
# PAY_APP_ID=
# PAY_API_KEY=
